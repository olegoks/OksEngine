                            "WorldScale3D",
                            "Model::ModelDataEntityId",
                            "ChildModelNodeEntities"
                        },
                        createsComponents = {
                            "AnimationInProgress"
                        },
                        removesComponents = {
                            "RunModelAnimation",
                            "AnimationInProgress",
                            "Animation::Model::Node::RunningState"
                        }
                    },

                },
                accessingEntities = {
                    {
                        accessingComponents = {
                            "ModelAnimations"
                        }
                    },
                    {
                        accessingComponents = {
                            "WorldPosition3D",
                            "WorldRotation3D",
                            "WorldScale3D",
                            "RunModelAnimation",
                            "PauseAnimation",
                            "AnimationInProgress"
                        },
                        removesComponents = {
