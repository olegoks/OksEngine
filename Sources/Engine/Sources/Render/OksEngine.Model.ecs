                        }
                    },
                    {
                        processesComponents = {
                            "Render::Model::Mesh::Tag",
                            "::Name",
                            { name = "Render::Model::EntityIds", readonly = false }
                        }
                    }
                }
            }
        },
        ProcessModelSystem = {
            callOrder = {
                runAfter = {
                    "RigidBodyWorldPositionToModelWorldPositionMapper"
